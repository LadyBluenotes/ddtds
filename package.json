{
  "name": "ddtds",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "lint": "oxlint . --max-warnings 0",
    "lint:fix": "oxlint . --fix",
    "bench": "pnpm --filter @ddtds/core bench",
    "typecheck": "pnpm -r run typecheck",
    "test": "pnpm -r test",
    "test:packages": "pnpm --filter './packages/*' run test",
    "test:examples": "pnpm --filter '@ddtds/example-*' test",
    "test:update-snapshots": "pnpm -r test -- -u",
    "knip": "knip"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "knip": "^6.7.0",
    "lefthook": "^2.1.6",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "tsx": "^4.21.0",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook"
    ]
  }
}
