{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "ignorePatterns": ["dist", "**/__doctests__"],
  "env": {
    "browser": true,
    "node": true,
    "es2026": true,
    "vitest": true
  },
  "options": {
    "typeAware": true
  },
  "plugins": ["eslint", "typescript", "unicorn", "vitest", "import", "node", "promise", "oxc"],
  "rules": {
    "no-console": "error",
    "no-shadow": "off"
  },
  "overrides": [
    {
      "files": ["packages/core/src/logger.ts"],
      "rules": {
        "no-console": "off"
      }
    }
  ],
  "categories": {
    "correctness": "error",
    "suspicious": "warn",
    "perf": "warn"
  }
}
